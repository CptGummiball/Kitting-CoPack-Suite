    {
      "id": "item-001",
      "sku": "KIT-PRO-2026",
      "name": "Premium Welcome Kit",
      "description": "Hochvertiges Willkommenspaket für Neukunden. Enthält personalisierte Begrüßungskarte, Produktproben und Informationsbroschüre.",
      "components": [
        {
          "id": "comp-001",
          "name": "Geschenkbox Premium (250x200x80mm)",
          "quantity": 1,
          "unit": "Stück",
          "notes": "Schwarz, matt"
        },
        {
          "id": "comp-002",
          "name": "Begrüßungskarte personalisiert",
          "quantity": 1,
          "unit": "Stück"
        },
        {
          "id": "comp-003",
          "name": "Produktprobe Set A",
          "quantity": 3,
          "unit": "Stück",
          "alternativeComponent": "Produktprobe Set B"
        },
        {
          "id": "comp-004",
          "name": "Informationsbroschüre 2026",
          "quantity": 1,
          "unit": "Stück"
        },
        {
          "id": "comp-005",
          "name": "Seidenpapier",
          "quantity": 2,
          "unit": "Bogen",
          "notes": "Weiß, säurefrei"
        },
        {
          "id": "comp-006",
          "name": "Aufkleber Logo",
          "quantity": 1,
          "unit": "Stück"
        }
      ],
      "instructions": [
        {
          "step": 1,
          "title": "Vorbereitung",
          "description": "Geschenkbox aufstellen und Seidenpapier zuschneiden. Box innen mit einem Bogen Seidenpapier auslegen."
        },
        {
          "step": 2,
          "title": "Hauptinhalt platzieren",
          "description": "Begrüßungskarte oben rechts, Produktproben mittig, Broschüre links platzieren."
        },
        {
          "step": 3,
          "title": "Abdeckung",
          "description": "Zweiten Bogen Seidenpapier oben auflegen und Deckel schließen."
        },
        {
          "step": 4,
          "title": "Versiegelung",
          "description": "Aufkleber mittig auf den Deckel kleben. Darauf achten, dass der Aufkleber gerade sitzt."
        },
        {
          "step": 5,
          "title": "Qualitätskontrolle",
          "description": "Verpackung auf Beschädigungen prüfen. Inhalt auf Vollständigkeit kontrollieren."
        }
      ],
      "specialNotes": "Achtung: Proben dürfen nicht gedrückt werden. Box vorsichtig handhaben.",
      "labelConfigs": [
        {
          "templateId": "lbl-001",
          "templateName": "Versandetikett Standard",
          "size": "100x150mm",
          "defaultQuantity": 1
        },
        {
          "templateId": "lbl-002",
          "templateName": "Produktlabel Klein",
          "size": "50x25mm",
          "defaultQuantity": 3
        }
      ],
      "packagingData": "Karton: 250x200x80mm, Gewicht netto: ~350g",
      "isActive": true,
      "createdAt": "2026-01-15T10:00:00Z",
      "updatedAt": "2026-03-10T14:00:00Z",
      "changeHistory": []
    },
